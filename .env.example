# Telegram API secrets (from https://my.telegram.org/apps)
# These three are the ONLY secrets needed in .env.
API_ID=
API_HASH=
PHONE=

# Channel destination, session name, ID3 tags, download dir, and
# audio bitrate are now tunable defaults in config.py — edit there,
# not here. See the TUNABLE DEFAULTS section at the top of config.py.
