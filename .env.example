# Telegram API (from https://my.telegram.org/apps)
API_ID=
API_HASH=
PHONE=

# Channel chat id to post into. Can be overridden on the CLI with --channel.
# Accepts any of:
#   1402888933            — public channel (no minus sign, no -100 prefix)
#   -1001234567890        — legacy/supergroup format
#   @channel_username     — public channel username
#   https://t.me/foo      — public channel invite link
#
# Quickest way to find it: forward any message from the channel to
# @userinfobot or @RawDataBot — the "Id" field is what you want.
CHANNEL_ID=

# Optional: your personal Telegram user id (for any future personal-send feature)
ADMIN_ID=
